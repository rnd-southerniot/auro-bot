# navbot.env — environment for the voice-appliance systemd stack (P7 autostart).
# Installed to /etc/navbot/navbot.env by scripts/install_autostart.sh. Edit there
# (or re-run the installer); the units load it via EnvironmentFile.

# --- ROS sourcing ---
ROS_SETUP=/opt/ros/jazzy/setup.bash
# External overlay that provides sllidar_ros2 (the LiDAR driver):
EXTERNAL_WORKSPACE_SETUP=/home/arif/ros2_ws/install/setup.bash
# This repo's built workspace (defaults to <repo>/ros2_ws/install/setup.bash if unset):
# WORKSPACE_SETUP=/home/arif/projects/claude-navbot/ros2_ws/install/setup.bash

# DDS — match the rest of the robot (CycloneDDS per the project decision log):
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
ROS_DOMAIN_ID=0

# --- web control surface ---
NAVBOT_WEB_PORT=8080
# NAVBOT_CAPTURE_ROOT=/home/arif/projects/claude-navbot/captures
# Bearer token for /api/* if the web console requires one (else leave unset):
# NAVBOT_WEB_TOKEN=

# --- bringup / nav extra launch args (optional) ---
# e.g. override the Pico serial path or log level:
# NAVBOT_BRINGUP_ARGS=serial_port:=/dev/serial/by-id/usb-Raspberry_Pi_Pico_E661410403114B35-if00
# NAVBOT_NAV_ARGS=

# --- camera (P6) ---
NAVBOT_CAMERA_URL=http://192.168.68.110

# --- voice brain ---
# Headless Claude Code brain (subscription OAuth) is preferred; make sure the CLI
# resolves and PATH includes ~/.local/bin:
PATH=/home/arif/.local/bin:/usr/local/bin:/usr/bin:/bin
NAVBOT_CLAUDE_BIN=/home/arif/.local/bin/claude
# STT / TTS:
WHISPER_MODEL=base.en
PIPER_BIN=/home/arif/piper/piper/piper
PIPER_VOICE=/home/arif/piper/en_US-amy-low.onnx
# Optional SDK fallback (metered API). Leave unset to stay on the subscription brain:
# ANTHROPIC_API_KEY=
# NAVBOT_VISION_MODEL=claude-sonnet-4-6
